@page "/progress"
@using driverightnepal.Core.Models
@using driverightnepal.Core.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject UserStateService UserState
@inject IJSRuntime JS

<head>
    <link href="css/progress.css" rel="stylesheet" />
</head>

<div class="main-container">
    <div class="header-container">
        <span class="header-title">My Progress</span>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <p>Calculating your achievements...</p>
        </div>
    }
    else
    {
        <div class="progress-container">
            <div class="progress-card">
                <h2 class="title">Your Progress</h2>

                <div class="progress-circle" style="background: conic-gradient(#5686E1 @(overallPercentage * 3.6)deg, #e0e0e0 0deg);">
                    <div class="inner-circle">
                        <span class="percentage">@overallPercentage%</span>
                    </div>
                </div>

                <div class="lesson-info">
                    <span class="completed">@completedCount</span>
                    <span>out of</span>
                    <span class="total">@totalLessonsCount</span>
                    <span>Lessons Completed</span>
                </div>
            </div>
        </div>

        <div class="chapter-progress">
            <p class="chapter-title">Chapter Progress:</p>
            <div class="chapters-container">
                @foreach (var chapter in ChapterStats)
                {
                    <div class="chapter-item">
                        <span class="chapter-name">@chapter.Name</span>
                        <div class="progress-bar">
                            <div class="progress" style="width: @chapter.Percentage%;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="quiz-chart-card">
            <p class="chapter-title">Recent Quiz Performance</p>
            @if (QuizScores.Any())
            {
                <div class="chart-wrapper">
                    <canvas id="quizChart"></canvas>
                </div>
            }
            else
            {
                <p style="text-align:center; color:#888; padding: 20px;">No quiz attempts yet.</p>
            }
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private int completedCount;
    private int totalLessonsCount;
    private int overallPercentage;
    
    private List<ChapterProgressInfo> ChapterStats = new();
    private List<string> Labels = new();
    private List<int> QuizScores = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProgressData();
    }

    private async Task LoadProgressData()
    {
        using var ctx = await DbFactory.CreateDbContextAsync();
        var userId = UserState.CurrentUser?.Id ?? 0;

        totalLessonsCount = await ctx.Lessons.CountAsync();
        var userProgress = await ctx.UserProgress
            .Where(up => up.UserId == userId && up.IsCompleted)
            .ToListAsync();
        
        completedCount = userProgress.Count;
        overallPercentage = totalLessonsCount > 0 ? (completedCount * 100 / totalLessonsCount) : 0;

        var allLessons = await ctx.Lessons.ToListAsync();
        var lessonsByCategory = allLessons.GroupBy(l => l.Category ?? "General");

        ChapterStats = lessonsByCategory.Select(group =>
        {
            var totalInChapter = group.Count();
            var completedInChapter = userProgress.Count(up => group.Any(l => l.Id == up.LessonId));
            return new ChapterProgressInfo
            {
                Name = group.Key,
                Percentage = totalInChapter > 0 ? (completedInChapter * 100 / totalInChapter) : 0
            };
        }).ToList();

        var quizAttempts = await ctx.QuizAttempts
            .Where(qa => qa.UserId == userId)
            .OrderBy(qa => qa.AttemptDate)
            .Take(5)
            .ToListAsync();

        Labels = Enumerable.Range(1, quizAttempts.Count)
                          .Select(i => i.ToString())
                          .ToList();

        QuizScores = quizAttempts.Select(qa => qa.ScorePercentage).ToList();
        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && QuizScores.Any())
        {
            await Task.Delay(100);
            await JS.InvokeVoidAsync("renderQuizChart", Labels.ToArray(), QuizScores.ToArray());
        }
    }

    private class ChapterProgressInfo
    {
        public string Name { get; set; } = "";
        public int Percentage { get; set; }
    }
}