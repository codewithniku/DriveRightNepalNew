@page "/verify-otp/{UserId:int}"
@using driverightnepal.Core.Models
@using Microsoft.EntityFrameworkCore
@using driverightnepal.Core.Data
@using driverightnepal.Core.Services
@layout NormalLayout
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject UserStateService UserState
@inject IJSRuntime JS

<title>Verify OTP - Drive Right Nepal</title>
<head>
    <link href="css/login.css" rel="stylesheet" />
</head>

<div class="login-wrapper">
    <div class="login-container">
        <img src="images/logo.svg" class="login-logo" alt="Logo" />
        
        <h2 style="color: #333; margin-bottom: 8px; font-size: 1.5rem;">Verify Identity</h2>
        <p style="font-size: 14px; color: #666; margin-bottom: 20px;">
            Enter the 6-digit code sent to your email to continue.
        </p>

        @if (!string.IsNullOrEmpty(message))
        {
            <p style="color: #d9534f; font-size: 13px; margin-bottom: 16px; font-weight: 500;">@message</p>
        }

        <div class="form-group">
            <input type="text"
                   @bind="inputOtp"
                   class="form-input"
                   placeholder="Enter 6-digit OTP"
                   maxlength="6"
                   style="text-align: center; letter-spacing: 4px; font-weight: bold; font-size: 1.2rem;" />
        </div>

        <button type="button" class="login-btn" @onclick="HandleVerify">Verify & Login</button>

        <p class="signup-text">
            Didn't receive a code?
            <button class="signup-link" style="background: none; border: none; cursor: pointer; padding: 0;" @onclick="GoBack">Try Again</button>
        </p>
    </div>
</div>

<footer class="login-footer">
    © 2026 DriveRight Nepal. All rights reserved.
</footer>

@code {
    [Parameter] public int UserId { get; set; }
    private string inputOtp = string.Empty;
    private string message = string.Empty;

    private async Task HandleVerify()
    {
        message = string.Empty;

        if (string.IsNullOrWhiteSpace(inputOtp) || inputOtp.Length != 6)
        {
            message = "Please enter a valid 6-digit code.";
            return;
        }

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var user = await context.Users.FirstOrDefaultAsync(u => u.Id == UserId);

            if (user == null)
            {
                message = "Session expired. Please log in again.";
                return;
            }

            if (user.CurrentOtp == inputOtp && user.OtpExpiry > DateTime.UtcNow)
            {
                user.CurrentOtp = null;
                user.OtpExpiry = null;
                user.IsEmailVerified = true;

                context.Users.Update(user);
                await context.SaveChangesAsync();

                await SecureStorage.Default.SetAsync("logged_in_user_id", user.Id.ToString());
                UserState.CurrentUser = user;

                Nav.NavigateTo("/dashboard");
            }
            else if (user.OtpExpiry <= DateTime.UtcNow)
            {
                message = "Code expired. Please request a new one.";
            }
            else
            {
                message = "Invalid verification code.";
            }
        }
        catch (Exception ex)
        {
            message = "An error occurred. Please try again.";
            Console.WriteLine(ex.Message);
        }
    }

    private void GoBack() => Nav.NavigateTo("/login");
}