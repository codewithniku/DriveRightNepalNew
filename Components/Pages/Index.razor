@page "/"
@using driverightnepal.Core.Services
@using driverightnepal.Core.Data
@using Microsoft.EntityFrameworkCore
@inject UserStateService UserState
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav

@code {
    protected override async Task OnInitializedAsync()
    {
        string savedId = await SecureStorage.Default.GetAsync("logged_in_user_id");

        if (!string.IsNullOrEmpty(savedId) && int.TryParse(savedId, out int userId))
        {
            try
            {
                using var context = await DbFactory.CreateDbContextAsync();
                var user = await context.Users.FirstOrDefaultAsync(u => u.Id == userId);

                if (user != null)
                {
                    UserState.CurrentUser = user;
                    Nav.NavigateTo("/dashboard");
                    return;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Auto-login failed: {ex.Message}");
            }
        }

        Nav.NavigateTo("/register");
    }
}