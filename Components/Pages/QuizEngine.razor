@page "/quiz-engine/{QuizId:int}"
@using driverightnepal.Core.Models
@using driverightnepal.Core.Data
@using Microsoft.EntityFrameworkCore
@using System.Timers
@implements IDisposable
@inject IDbContextFactory<AppDbContext> DbFactory
@inject driverightnepal.Core.Services.UserStateService UserState
@inject NavigationManager Nav
@inject ConfigService Config
@inject IJSRuntime JS
@layout NormalLayout

<head>
    <link href="css/quiz.css" rel="stylesheet" />
    <link href="css/quiz-engine.css" rel="stylesheet" />
    <style>
            #quiz-pdf-container {
                width: 100%;
                background: #f8f9fa;
                border-radius: 12px;
                overflow: hidden;
                display: flex;
                flex-direction: column;
                align-items: center;
            }

                #quiz-pdf-container canvas {
                    max-width: 100% !important;
                    height: auto !important;
                    margin-bottom: 8px;
                    border-bottom: 1px solid #eee;
                }

            .pdf-placeholder {
                min-height: 200px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #888;
                font-size: 0.9rem;
                text-align: center;
                padding: 20px;
            }
    </style>
</head>

<div class="main-container">
    <div class="header-container">
        <button class="back-btn" @onclick="ExitQuiz">
            <img src="images/icons/BackTo.png" alt="Back" />
        </button>
        <span class="header-title">@quizTitle</span>
        <div class="header-stats">
            <div class="stat-box">
                <span class="stat-number">@(questions != null ? $"{currentQuestionIndex + 1}/{questions.Count}" : "-")</span>
                <span class="stat-label">Question</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@timeLeftStr</span>
                <span class="stat-label">Time Left</span>
            </div>
        </div>
    </div>

    @if (questions == null)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Preparing your test...</p>
        </div>
    }
    else if (isFinished && !isReviewMode)
    {
        <div class="form-container result-screen">
            <img src="images/icons/Trophy.png" style="width: 80px; margin-bottom: 15px;" />
            <h2 style="color: #333;">Test Completed!</h2>
            <div class="final-score">
                <span class="score-percent">@scorePercentage%</span>
                <p>Correct Answers: @correctAnswers / @questions.Count</p>
            </div>
            <div class="result-actions" style="display:flex; flex-direction:column; gap:10px; width:100%;">
                <button class="submit-btn" @onclick="GoToReview">Review Answers</button>
                <button class="nav-btn-prev" style="flex:1;" @onclick='() => Nav.NavigateTo("/quiz")'>Back to Menu</button>
            </div>
        </div>
    }
    else
    {
        <div class="form-container">
            @if (!isReviewMode)
            {
                <div class="progress-bar-container">
                    <div class="progress-fill" style="width: @(GetProgress())%"></div>
                </div>
            }

            @if (!string.IsNullOrEmpty(questions[currentQuestionIndex].ImagePath))
            {
                <div id="quiz-pdf-container" class="pdf-placeholder" style="margin-bottom: 15px;">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <span class="ms-2">Loading attachment...</span>
                </div>
            }

            <div class="question-header">
                <p class="question-text">@(currentQuestionIndex + 1). @questions[currentQuestionIndex].Text</p>
            </div>

            <div class="options-container">
                @foreach (var opt in new[] { "A", "B", "C", "D" })
                {
                    var optionText = GetOptionText(opt);
                    var cssClass = isReviewMode
                        ? GetReviewClass(currentQuestionIndex, opt, questions[currentQuestionIndex].CorrectOption)
                        : GetClass(opt);

                    <div class="option-item @cssClass" @onclick='() => { if (!isReviewMode) SelectOption(opt); }'>
                        <span class="option-label">@opt</span>
                        <span class="option-text">@optionText</span>
                    </div>
                }
            </div>

            <div class="engine-footer">
                <button class="nav-btn-prev" disabled="@(currentQuestionIndex == 0)" @onclick="Prev">Previous</button>

                @if (isReviewMode && currentQuestionIndex == questions.Count - 1)
                {
                    <button class="submit-btn" @onclick='() => Nav.NavigateTo("/quiz")'>Exit Review</button>
                }
                else
                {
                    <button class="submit-btn @(HasSelected() || isReviewMode ? "" : "btn-disabled")"
                            disabled="@(!HasSelected() && !isReviewMode)"
                            @onclick="HandleNextStep">
                        @(currentQuestionIndex == questions.Count - 1 && !isReviewMode ? "Finish" : "Next")
                    </button>
                }
            </div>
        </div>
    }

    @if (showExitModal)
    {
        <div class="modal-overlay">
            <div class="modal-card">
                <div class="modal-icon">⚠️</div>
                <h3>Quit Quiz?</h3>
                <p>Your progress will be lost. Exit now?</p>
                <div class="modal-actions">
                    <button class="modal-btn-cancel" @onclick="() => showExitModal = false">Continue</button>
                    <button class="modal-btn-confirm" @onclick="ConfirmExit">Exit Now</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int QuizId { get; set; }
    private List<Question>? questions;
    private string quizTitle = "Loading...";
    private Dictionary<int, string> userAnswers = new();
    private int currentQuestionIndex = 0;
    private int lastRenderedIndex = -1;
    private Timer? timer;
    private int totalSeconds;
    private string timeLeftStr = "00:00";
    private bool isFinished = false;
    private bool isReviewMode = false;
    private bool showExitModal = false;
    private int scorePercentage = 0;
    private int correctAnswers = 0;

    private HttpClient _http = new HttpClient(new HttpClientHandler
    {
        ServerCertificateCustomValidationCallback = (message, cert, chain, errors) => true
    });

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        using var ctx = await DbFactory.CreateDbContextAsync();
        var quiz = await ctx.Quizzes.FindAsync(QuizId);
        if (quiz != null)
        {
            quizTitle = quiz.Title;
            totalSeconds = quiz.TimeLimitMinutes * 60;
            questions = await ctx.Questions.Where(q => q.QuizId == QuizId).ToListAsync();
            if (questions != null && questions.Any()) StartTimer();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (questions != null && currentQuestionIndex < questions.Count && currentQuestionIndex != lastRenderedIndex)
        {
            var currentQ = questions[currentQuestionIndex];
            if (!string.IsNullOrEmpty(currentQ.ImagePath))
            {
                lastRenderedIndex = currentQuestionIndex;
                await RenderQuestionPdf(currentQ.ImagePath);
            }
            else { lastRenderedIndex = currentQuestionIndex; }
        }
    }

    private async Task RenderQuestionPdf(string path)
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "var el = document.getElementById('quiz-pdf-container'); if(el) el.innerHTML = '';");
            var cleanPath = path.StartsWith("/") ? path : "/" + path;
            var fullUrl = $"{Config.BaseUrl}{cleanPath}";
            var pdfBytes = await _http.GetByteArrayAsync(fullUrl);
            var base64 = Convert.ToBase64String(pdfBytes);
            await Task.Delay(50);
            await JS.InvokeVoidAsync("renderPdf", base64, "quiz-pdf-container");
        }
        catch (Exception ex) { Console.WriteLine($"PDF Error: {ex.Message}"); }
    }

    private void GoToReview()
    {
        isReviewMode = true;
        currentQuestionIndex = 0;
        lastRenderedIndex = -1;
        StateHasChanged();
    }

    private async Task HandleNextStep()
    {
        if (currentQuestionIndex == questions.Count - 1 && !isReviewMode) await FinishQuiz();
        else Next();
    }

    private void Next() { if (currentQuestionIndex < questions.Count - 1) currentQuestionIndex++; StateHasChanged(); }
    private void Prev() { if (currentQuestionIndex > 0) currentQuestionIndex--; StateHasChanged(); }

    private string GetOptionText(string opt) => opt switch
    {
        "A" => questions![currentQuestionIndex].OptionA,
        "B" => questions![currentQuestionIndex].OptionB,
        "C" => questions![currentQuestionIndex].OptionC,
        _ => questions![currentQuestionIndex].OptionD
    };

    private void StartTimer()
    {
        timer = new Timer(1000);
        timer.Elapsed += (s, e) =>
        {
            if (totalSeconds > 0)
            {
                totalSeconds--;
                timeLeftStr = TimeSpan.FromSeconds(totalSeconds).ToString(@"mm\:ss");
                InvokeAsync(StateHasChanged);
            }
            else { InvokeAsync(FinishQuiz); }
        };
        timer.AutoReset = true;
        timer.Start();
    }

    private double GetProgress() => (double)(currentQuestionIndex + 1) / questions!.Count * 100;
    private bool HasSelected() => userAnswers.ContainsKey(currentQuestionIndex);
    private void SelectOption(string opt) => userAnswers[currentQuestionIndex] = opt;
    private string GetClass(string opt) => userAnswers.GetValueOrDefault(currentQuestionIndex) == opt ? "selected" : "";

    private string GetReviewClass(int qIndex, string opt, string correctOpt)
    {
        var userOpt = userAnswers.GetValueOrDefault(qIndex);
        if (opt == correctOpt) return "review-correct";
        if (userOpt == opt && userOpt != correctOpt) return "review-wrong";
        return "";
    }

    private async Task FinishQuiz()
    {
        if (isFinished || questions == null) return;
        timer?.Stop();

        var uid = UserState.CurrentUser?.Id ?? 0;
        correctAnswers = questions.Count(q => userAnswers.GetValueOrDefault(questions.IndexOf(q)) == q.CorrectOption);
        scorePercentage = (int)((double)correctAnswers / questions.Count * 100);

        using var ctx = await DbFactory.CreateDbContextAsync();

        foreach (var q in questions)
        {
            var userAns = userAnswers.GetValueOrDefault(questions.IndexOf(q));
            var isCorrect = userAns == q.CorrectOption;
            
            var mistake = await ctx.UserMistakes
                .FirstOrDefaultAsync(m => m.UserId == uid && m.QuestionId == q.Id);

            if (!isCorrect && !string.IsNullOrEmpty(userAns))
            {
                if (mistake == null)
                    ctx.UserMistakes.Add(new UserMistake { UserId = uid, QuestionId = q.Id, RepeatCount = 2 });
                else
                {
                    mistake.RepeatCount += 1;
                    mistake.LastFailed = DateTime.Now;
                }
            }
            else if (isCorrect && mistake != null)
            {
                mistake.RepeatCount = Math.Max(0, mistake.RepeatCount - 1);
            }
        }

        ctx.QuizAttempts.Add(new QuizAttempt
        {
            UserId = uid,
            QuizId = QuizId,
            ScorePercentage = scorePercentage,
            AttemptDate = DateTime.Now,
            Category = quizTitle
        });

        await ctx.SaveChangesAsync();
        isFinished = true;
        StateHasChanged();
    }

    private void ExitQuiz() { if (isFinished) Nav.NavigateTo("/quiz"); else showExitModal = true; }
    private void ConfirmExit() { timer?.Stop(); Nav.NavigateTo("/quiz"); }
    public void Dispose() { timer?.Stop(); timer?.Dispose(); }
}