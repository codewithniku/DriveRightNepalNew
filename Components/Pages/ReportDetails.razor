@page "/report-details/{ReportId:int}"
@using driverightnepal.Core.Models
@using driverightnepal.Core.Data
@using Microsoft.EntityFrameworkCore
@using System.IO
@layout NormalLayout
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject ConfigService Config

<head>
    <link href="css/report.css" rel="stylesheet" />
</head>

<div class="main-container">
    <div class="header-container" style='background-color: @(report?.Status == "Rejected" ? "#E32222" : "#009132")'>
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/violation-history")'>
            <img src="images/icons/BackTo.png" alt="Back" />
        </button>
        <span class="header-title">Report Review</span>
        <span class="header-subtitle">Status: @report?.Status @(report?.Status == "Resolved" ? "✅" : "❌")</span>
    </div>

    @if (report != null)
    {
        <div class="form-container">
            <div class="form-group">
                <label>Evidence Submitted</label>
                
                <div class="evidence-preview" style="background: #000; border-radius: 12px; overflow: hidden; min-height: 200px; display: flex; align-items: center; justify-content: center; position: relative;">
                    
                    @if (isDownloading)
                    {
                        <div style="color: white; text-align: center;">
                            <div class="spinner-border text-light" role="status"></div>
                            <p>Loading evidence...</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(mediaDataUrl))
                    {
                        var fileExt = Path.GetExtension(report.MediaPath).ToLower();

                        @if (fileExt == ".mp4" || fileExt == ".mov" || fileExt == ".avi")
                        {
                            <video controls playsinline style="width: 100%; max-height: 250px; background: #000;" src="@mediaDataUrl">
                                Your browser does not support the video tag.
                            </video>
                        }
                        else
                        {
                            <img src="@mediaDataUrl" style="width: 100%; max-height: 250px; object-fit: contain;" />
                        }
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(report.AdminRemarks))
            {
                <div class="form-group">
                    <label style="color: #E32222; font-weight: 700;">Officer Remarks</label>
                    <div class="form-control" style="background-color: #FFF5F5; border-color: #FEB2B2; color: #C53030; min-height: 50px;">
                        @report.AdminRemarks
                    </div>
                </div>
            }

            <div class="form-group">
                <label>Violation Type</label>
                <div class="form-control" style="background: #f9f9f9;">@report.ViolationType</div>
            </div>

            <div class="form-group">
                <label>Location</label>
                <div class="form-control" style="background: #f9f9f9;">@report.Location</div>
            </div>

            <div class="row-group">
                <div class="form-group" style="width: 100%;">
                    <label>Incident Date & Time</label>
                    <div class="form-control" style="background: #f9f9f9;">
                        @report.IncidentDateTime.ToString("MMMM dd, yyyy - hh:mm tt")
                    </div>
                </div>
            </div>

            <div class="section-title">Vehicle Details</div>

            <div class="form-group">
                <label>Vehicle Number</label>
                <div class="form-control" style="background: #f9f9f9; font-family: monospace; font-weight: bold;">
                    @report.VehicleNumber
                </div>
            </div>

            <div class="form-group">
                <label>Vehicle Info</label>
                <div class="form-control" style="background: #f9f9f9;">
                    @report.VehicleColor @report.VehicleType
                </div>
            </div>

            <div class="form-group">
                <label>Your Description</label>
                <div class="form-control" style="background: #f9f9f9; min-height: 80px;">
                    @report.Description
                </div>
            </div>

            <button class="submit-btn" style='background-color: @(report.Status == "Rejected" ? "#E32222" : "#009132"); box-shadow: none; margin-bottom: 20px;'
                    @onclick='() => Nav.NavigateTo("/notifications")'>
                Back to Notifications
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public int ReportId { get; set; }
    private ViolationReport? report;
    private string? mediaDataUrl;
    private bool isDownloading = false;

    protected override async Task OnInitializedAsync()
    {
        using var ctx = await DbFactory.CreateDbContextAsync();
        report = await ctx.ViolationReports.FindAsync(ReportId);

        if (report != null)
        {
            if (!report.IsRead)
            {
                report.IsRead = true;
                await ctx.SaveChangesAsync();
            }
            await LoadMediaAsync();
        }
    }

    private async Task LoadMediaAsync()
    {
        if (string.IsNullOrEmpty(report?.MediaPath)) return;

        string cacheFileName = report.MediaPath;
        string targetPath = Path.Combine(FileSystem.CacheDirectory, cacheFileName);

        try
        {
            byte[] fileData;

            if (File.Exists(targetPath))
            {
                fileData = await File.ReadAllBytesAsync(targetPath);
            }
            else
            {
                isDownloading = true;
                StateHasChanged();

                string remoteUrl = $"{Config.BaseUrl.TrimEnd('/')}/uploads/{report.MediaPath}";
                using var client = new HttpClient();
                fileData = await client.GetByteArrayAsync(remoteUrl);
                
                await File.WriteAllBytesAsync(targetPath, fileData);
            }

            string contentType = GetContentType(targetPath);
            string base64 = Convert.ToBase64String(fileData);
            mediaDataUrl = $"data:{contentType};base64,{base64}";
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading media: {ex.Message}");
        }
        finally
        {
            isDownloading = false;
            StateHasChanged();
        }
    }

    private string GetContentType(string path)
    {
        var ext = Path.GetExtension(path).ToLower();
        return ext switch
        {
            ".png" => "image/png",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".gif" => "image/gif",
            ".mp4" => "video/mp4",
            ".mov" => "video/quicktime",
            _ => "application/octet-stream"
        };
    }
}