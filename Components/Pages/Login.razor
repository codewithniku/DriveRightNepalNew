@page "/login"
@using driverightnepal.Core.Models
@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore
@using driverightnepal.Core.Data
@using driverightnepal.Core.Services
@layout NormalLayout
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject UserStateService UserState
@inject IEmailService EmailService
@inject IJSRuntime JS

<title>Login</title>
<head>
    <link href="css/login.css" rel="stylesheet" />
</head>

<div class="login-wrapper">
    <div class="login-container">
        <img src="images/logo.svg" class="login-logo" />
        <p>Welcome back! Please log in to your account.</p>
        
        @if (!string.IsNullOrEmpty(message))
        {
            <p class="form-message">@message</p>
        }

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <InputText @bind-Value="loginModel.Email" type="email" class="form-input" placeholder="Email address" />
                <ValidationMessage For="@(() => loginModel.Email)" />
            </div>

            <div class="form-group">
                <InputText @bind-Value="loginModel.Password" type="password" class="form-input" placeholder="Password" />
                <ValidationMessage For="@(() => loginModel.Password)" />
            </div>

            <button type="submit" class="login-btn">Login</button>
        </EditForm>

        <p class="signup-text">
            Don't have an account?
            <NavLink class="signup-link" href="/register">Sign Up</NavLink>
        </p>
    </div>
</div>

<footer class="login-footer">
    © 2026 DriveRight Nepal. All rights reserved.
</footer>

@code {
    private LoginModel loginModel = new LoginModel();
    private string message = string.Empty;

    private async Task HandleLogin()
    {
        message = string.Empty;

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            var user = await context.Users.FirstOrDefaultAsync(u => u.Email == loginModel.Email);

            if (user == null)
            {
                message = "Invalid email or password.";
                return;
            }

            var inputHash = HashPassword(loginModel.Password);

            if (user.PasswordHash == inputHash)
            {
                string otp = new Random().Next(100000, 999999).ToString();
                
                user.CurrentOtp = otp;
                user.OtpExpiry = DateTime.UtcNow.AddMinutes(5);
                
                context.Users.Update(user);
                await context.SaveChangesAsync();

                try
                {
                    string subject = "Your Drive Right Nepal Login Code";
                    string body = $@"
                        <div style='font-family: Arial, sans-serif;'>
                            <h2>Login Verification</h2>
                            <p>Your one-time password (OTP) for Drive Right Nepal is:</p>
                            <h1 style='color: #009132; letter-spacing: 5px;'>{otp}</h1>
                            <p>This code will expire in 5 minutes.</p>
                            <p>If you did not request this code, please ignore this email.</p>
                        </div>";

                    await EmailService.SendEmailAsync(user.Email, subject, body);
                }
                catch (Exception ex)
                {
                    message = "Failed to send OTP email. Please try again later.";
                    return;
                }

                Nav.NavigateTo($"/verify-otp/{user.Id}");
            }
            else
            {
                message = "Invalid email or password.";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private string HashPassword(string password)
    {
        using var sha256 = System.Security.Cryptography.SHA256.Create();
        var bytes = System.Text.Encoding.UTF8.GetBytes(password);
        var hashBytes = sha256.ComputeHash(bytes);
        return Convert.ToBase64String(hashBytes);
    }

    public class LoginModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;
        [Required]
        public string Password { get; set; } = string.Empty;
    }
}