@page "/quiz"
@using driverightnepal.Core.Models
@using driverightnepal.Core.Data
@using Microsoft.EntityFrameworkCore
@layout MainLayout
@inject IDbContextFactory<AppDbContext> DbFactory
@inject UserStateService UserState
@inject NavigationManager Nav

<head>
    <link href="css/quiz.css" rel="stylesheet" />
</head>

<div class="main-container">
    <div class="header-container">
        <button class="back-btn" @onclick="GoBack">
            <img src="images/icons/BackTo.png" alt="Back" />
        </button>

        <span class="header-title">Practice Tests</span>

        <div class="header-stats">
            <div class="stat-box">
                <span class="stat-number">@completedCount/@totalQuizzes</span>
                <span class="stat-label">Completed</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@((int)avgScore)%</span>
                <span class="stat-label">Avg Score</span>
            </div>
            <div class="stat-box">
                <span class="stat-number">@bestScore%</span>
                <span class="stat-label">Best Score</span>
            </div>
        </div>
    </div>

    <div class="quizzes-container">
        @if (quizList == null)
        {
            <p style="text-align:center; padding: 20px;">Loading Quizzes...</p>
        }
        else
        {
            @foreach (var quiz in quizList)
            {
                <div class="quiz-card">
                    <span class="quiz-title">@quiz.Title</span>

                    <div class="quiz-info">
                        <div class="quiz-info-item">
                            <img src="images/icons/Goal.png" alt="Questions" />
                            <span>@quiz.QuestionsCount questions</span>
                        </div>
                        <div class="quiz-info-item">
                            <img src="images/icons/Clock.png" alt="Time" />
                            <span>@quiz.TimeMinutes mins</span>
                        </div>
                        <div class="quiz-info-item">
                            <img src="images/icons/Trophy.png" alt="High Score" />
                            <span>@(quiz.HighScore.HasValue ? $"{quiz.HighScore.Value}%" : "-")</span>
                        </div>
                    </div>

                    <div class="quiz-divider"></div>

                    <div class="quiz-footer">
                        <span>@quiz.AttemptedTimes attempts</span>
                        <button class="quiz-action" @onclick="() => TakeQuiz(quiz.Id)">
                            @(quiz.AttemptedTimes > 0 ? "Retake Quiz" : "Take Quiz")
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<QuizDisplayModel> quizList = new();
    private int completedCount;
    private int totalQuizzes;
    private double avgScore;
    private int bestScore;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsLoggedIn) return;

        using var ctx = await DbFactory.CreateDbContextAsync();

        var dbQuizzes = await ctx.Quizzes.ToListAsync();
        var userAttempts = await ctx.QuizAttempts
            .Where(a => a.UserId == UserState.CurrentUser.Id)
            .ToListAsync();

        quizList = dbQuizzes.Select(q =>
        {
            var attemptsForThisQuiz = userAttempts.Where(a => a.QuizId == q.Id).ToList();
            return new QuizDisplayModel
            {
                Id = q.Id,
                Title = q.Title,
                QuestionsCount = q.TotalQuestions,
                TimeMinutes = q.TimeLimitMinutes,
                AttemptedTimes = attemptsForThisQuiz.Count,
                HighScore = attemptsForThisQuiz.Any() ? attemptsForThisQuiz.Max(a => a.ScorePercentage) : null
            };
        }).ToList();

        totalQuizzes = quizList.Count;
        completedCount = quizList.Count(q => q.AttemptedTimes > 0);
        if (userAttempts.Any())
        {
            avgScore = userAttempts.Average(a => a.ScorePercentage);
            bestScore = userAttempts.Max(a => a.ScorePercentage);
        }
    }

    void GoBack() => Nav.NavigateTo("/dashboard");

    void TakeQuiz(int quizId)
    {
        Nav.NavigateTo($"/quiz-engine/{quizId}");
    }

    public class QuizDisplayModel
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public int QuestionsCount { get; set; }
        public int TimeMinutes { get; set; }
        public int? HighScore { get; set; }
        public int AttemptedTimes { get; set; }
    }
}