@page "/violation"
@inject NavigationManager Nav
@inject UserStateService UserState
@layout NormalLayout
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@using driverightnepal.Core.Models
@using driverightnepal.Core.Data
@using driverightnepal.Core.Services
@using System.IO

<head>
    <link href="css/report.css" rel="stylesheet" />
</head>

<div class="main-container">
    

    <div class="header-container">
        <button class="back-btn" @onclick="GoBack">
            <img src="images/icons/BackTo.png" alt="Back" />
        </button>
        <span class="header-title">Report Violation</span>
        <span class="header-subtitle">Help make Nepal roads safer 🚦</span>
    </div>


    <div class="form-container">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="margin-bottom: 20px; padding: 12px; background-color: #f8d7da; color: #721c24; border-radius: 4px; border: 1px solid #f5c6cb;">
                @errorMessage
            </div>
        }
        <div class="form-group">
            <label>Upload Photo or Video *</label>
            <InputFile OnChange="HandleFileUpload" accept="image/*,video/*" />
        </div>

        <div class="form-group">
            <label>Violation Type *</label>
            <select class="form-control" @bind="ViolationType">
                <option value="">-- Select Violation --</option>
                <option>Red Light Violation</option>
                <option>Over Speeding</option>
                <option>Illegal Parking</option>
                <option>Wrong Lane Driving</option>
                <option>No Helmet</option>
                <option>Drunk Driving</option>
                <option>Reckless Driving</option>
                <option>Driving While Using Phone</option>
                <option>Other</option>
            </select>
        </div>

        <div class="form-group">
            <label>Location *</label>
            <input type="text" class="form-control" placeholder="Fetching location..." @bind="LocationAddress" />
            <button class="location-btn" @onclick="GetCurrentLocation">Use Current Location</button>
        </div>

        <div class="row-group">
            <div class="form-group">
                <input type="date" class="form-control" @bind="IncidentDateTime" @bind:format="yyyy-MM-dd" />
            </div>
            <div class="form-group">
                <input type="time" class="form-control" @bind="IncidentDateTime" @bind:format="HH:mm" />
            </div>
        </div>

        <div class="section-title">Vehicle Details</div>

        <div class="form-group">
            <label>Vehicle Number *</label>
            <input type="text" class="form-control" placeholder="BA 2 CHA 1234" @bind="VehicleNumber" />
        </div>

        <div class="form-group">
            <label>Vehicle Color</label>
            <input type="text" class="form-control" placeholder="e.g. Red, Black" @bind="VehicleColor" />
        </div>

        <div class="form-group">
            <label>Vehicle Type</label>
            <select class="form-control" @bind="VehicleType">
                <option value="">-- Select Type --</option>
                <option>Motorcycle</option>
                <option>Car</option>
                <option>Bus</option>
                <option>Truck</option>
                <option>Taxi</option>
                <option>Other</option>
            </select>
        </div>

        <div class="form-group">
            <label>Additional Details</label>
            <textarea class="form-control" rows="4" placeholder="Describe what happened..." @bind="Description"></textarea>
        </div>

        <div class="form-group checkbox-group">
            <input type="checkbox" @bind="IsUrgent" />
            <label>Mark as Urgent 🚨</label>
        </div>

        <button class="submit-btn @(isSubmitting ? "btn-disabled" : "")"
                disabled="@isSubmitting"
                @onclick="SubmitReport">
            @(isSubmitting ? "Uploading... Please wait" : "Submit Report")
        </button>
    </div>
</div>

@code {
    private string? ViolationType;
    private string? LocationAddress;
    private DateTime IncidentDateTime = DateTime.Now;
    private string? VehicleNumber;
    private string? VehicleColor;
    private string? VehicleType;
    private string? Description;
    private bool IsUrgent;
    private IBrowserFile? selectedFile;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    void GoBack() => Nav.NavigateTo("/dashboard");

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task GetCurrentLocation()
    {
        var status = await Permissions.CheckStatusAsync<Permissions.LocationWhenInUse>();
        if (status != PermissionStatus.Granted)
        {
            status = await Permissions.RequestAsync<Permissions.LocationWhenInUse>();
        }

        if (status == PermissionStatus.Granted)
        {
            var location = await Geolocation.Default.GetLocationAsync(new GeolocationRequest(GeolocationAccuracy.Medium));
            //LocationAddress = location != null ? $"{location.Latitude}, {location.Longitude}" : "Location not found";
            LocationAddress = location != null ? "Location Fetched" : "Location not found";

        }
    }

    private async Task SubmitReport()
    {
        if (selectedFile == null)
        {
            errorMessage = "Please select a photo or video";
            StateHasChanged();
            return;
        }

        if (string.IsNullOrEmpty(ViolationType))
        {
            errorMessage = "Please select a violation type";
            StateHasChanged();
            return;
        }

        if (string.IsNullOrEmpty(LocationAddress))
        {
            errorMessage = "Please provide a location";
            StateHasChanged();
            return;
        }

        if (string.IsNullOrEmpty(VehicleNumber))
        {
            errorMessage = "Please enter vehicle number";
            StateHasChanged();
            return;
        }

        isSubmitting = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var content = new MultipartFormDataContent();
            var fileStream = selectedFile.OpenReadStream(100 * 1024 * 1024);
            var streamContent = new StreamContent(fileStream);
            content.Add(streamContent, "file", selectedFile.Name);

            using var client = new HttpClient(GetInsecureHandler());
            client.Timeout = TimeSpan.FromMinutes(5);
        
            var response = await client.PostAsync("http://10.0.2.2:5015/api/upload", content);

            if (!response.IsSuccessStatusCode)
            {
                throw new Exception($"Server upload failed: {response.StatusCode}");
            }

            var uploadResult = await response.Content.ReadFromJsonAsync<UploadResponse>();
            string serverFileName = uploadResult?.fileName ?? "";

            using var ctx = await DbFactory.CreateDbContextAsync();
        
            if (UserState.CurrentUser == null)
            {
                errorMessage = "User session expired. Please log in again.";
                return;
            }

            var report = new ViolationReport
            {
                UserId = UserState.CurrentUser.Id,
                ViolationType = ViolationType ?? "Other",
                Location = LocationAddress ?? "Unknown",
                IncidentDateTime = IncidentDateTime,
                VehicleNumber = VehicleNumber ?? "Unknown",
                VehicleColor = VehicleColor,
                VehicleType = VehicleType,
                Description = Description,
                IsUrgent = IsUrgent,
                MediaPath = serverFileName,
                Status = "Pending",
                SubmittedAt = DateTime.UtcNow
            };

            ctx.ViolationReports.Add(report);
            await ctx.SaveChangesAsync();

            Nav.NavigateTo("/violation-history");
        }
        catch (Exception ex)
        {
            errorMessage = ex.InnerException?.Message ?? ex.Message;
            errorMessage = $"Error: {ex.Message}";
            StateHasChanged();
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    public HttpClientHandler GetInsecureHandler()
    {
        var handler = new HttpClientHandler();
        handler.ServerCertificateCustomValidationCallback = (message, cert, chain, errors) => true;
        return handler;
    }

    public class UploadResponse
    {
        public string fileName { get; set; } = string.Empty;
    }
}