@inherits LayoutComponentBase
@using Microsoft.Maui.Devices
@using driverightnepal.Core.Services
@using Microsoft.Maui.Storage
@inject UserStateService UserState
@inject NavigationManager Nav

<div class="main-layout @ActiveTheme">
    <div class="safe-area">
        @Body
    </div>

    @if (UserState.IsLoggedIn)
    {
        <div class="bottom-nav">
            <div class="nav-item @(IsActive("/dashboard") ? "active" : "")" @onclick='() => NavigateTo("/dashboard")'>
                <div class="nav-inner">
                    <img src="images/icons/navigations/Home.png" alt="Home" />
                </div>
            </div>

            <div class="nav-item @(IsActive("/quiz") ? "active" : "")" @onclick='() => NavigateTo("/quiz")'>
                <div class="nav-inner">
                    <img src="images/icons/navigations/Tests.png" alt="Quiz" />
                </div>
            </div>

            @if (DeviceInfo.Current.Idiom == DeviceIdiom.Desktop)
            {
                <div class="nav-item @(IsActive("/admin") ? "active" : "")" @onclick='() => NavigateTo("/admin")' style="background: rgba(255, 215, 0, 0.1); border-radius: 12px;">
                    <div class="nav-inner">
                        <span class="oi oi-shield" style="color: #f1c40f; font-size: 1.4rem;"></span>
                    </div>
                </div>
            }

            <div class="nav-item @(IsActive("/progress") ? "active" : "")" @onclick='() => NavigateTo("/progress")'>
                <div class="nav-inner">
                    <img src="images/icons/navigations/Progress.png" alt="Progress" />
                </div>
            </div>

            <div class="nav-item @(IsActive("/profile") ? "active" : "")" @onclick='() => NavigateTo("/profile")'>
                <div class="nav-inner">
                    <img src="images/icons/navigations/Profile.png" alt="Profile" />
                </div>
            </div>
        </div>
    }
</div>

<style>
    .safe-area {
        padding-top: env(safe-area-inset-top);
        padding-bottom: 80px;
    }

    .oi-shield {
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

@code {
    private string currentPath = "";

    protected override async Task OnInitializedAsync()
    {
        UpdatePath();

        Nav.LocationChanged += (s, e) =>
        {
            UpdatePath();
            StateHasChanged();
        };

        var savedId = await SecureStorage.Default.GetAsync("logged_in_user_id");
        
        if (string.IsNullOrEmpty(savedId))
        {
            if (IsProtectedRoute(currentPath))
            {
                Nav.NavigateTo("/login");
            }
        }

        // No more isLoading or Task.Delay here
    }

    private bool IsProtectedRoute(string path)
    {
        var protectedPaths = new[] { "/dashboard", "/profile", "/quiz", "/progress" };
        return protectedPaths.Any(p => path.StartsWith(p)) || path == "/";
    }

    void UpdatePath()
    {
        currentPath = Nav.Uri.Replace(Nav.BaseUri, "/");
        if (currentPath.Length > 1 && currentPath.EndsWith("/"))
            currentPath = currentPath.TrimEnd('/');
        else if (string.IsNullOrEmpty(currentPath))
            currentPath = "/";
    }

    bool IsActive(string url) => currentPath == url;

    string ActiveTheme => currentPath switch
    {
        "/dashboard" => "theme-home",
        "/quiz" => "theme-quiz",
        "/progress" => "theme-progress",
        "/profile" => "theme-profile",
        "/admin" => "theme-admin",
        _ => ""
    };

    void NavigateTo(string url) => Nav.NavigateTo(url);
}